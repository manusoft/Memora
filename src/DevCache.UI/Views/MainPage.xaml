<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DevCache.UI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevCache.UI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls" 
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToObjectConverter x:Key="NullToVisibilityConverter"
                                      TrueValue="Visible"
                                      FalseValue="Collapsed" />

        <!-- Inverts bool: true → false, false → true -->
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />

        <!-- bool true → Visible, false → Collapsed -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <StackPanel Orientation="Horizontal">
            <AppBarButton Icon="Refresh" 
                          Label="Refresh"
                          Command="{x:Bind ViewModel.RefreshCommand}"
                          IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>
            <AppBarSeparator />
            <AppBarButton Icon="Remove" 
                          Label="Flush All"
                          Command="{x:Bind ViewModel.FlushDbCommand}"/>
            <AppBarSeparator/>
            <AppBarButton x:Name="DeleteKeyButton"
                          Icon="Delete" 
                          Label="Delete Key"
                          Click="DeleteKeyButton_Click"
                          IsEnabled="{x:Bind ViewModel.HasSelectedEntry, Mode=OneWay}"/>
            <TeachingTip
                 x:Name="DeleteKeyTeachingTip"
                 Title="Delete Key?"
                 Subtitle="Are you sure do you want to delete key?"
                 ActionButtonContent="Yes"
                 ActionButtonCommand="{x:Bind ViewModel.DeleteSelectedCommand}"
                 ActionButtonClick="DeleteKeyTeachingTip_ActionButtonClick"
                 CloseButtonContent="No"
                 IsLightDismissEnabled="False"
                 PlacementMargin="20"
                 Target="{x:Bind DeleteKeyButton}">
                <TeachingTip.IconSource>
                    <SymbolIconSource Symbol="Delete"/>
                </TeachingTip.IconSource>
            </TeachingTip>

            <AppBarSeparator />
            <AppBarButton x:Name="SetKeyButton"
                          Icon="Edit" 
                          Label="Add / Edit"
                          Click="SetKeyButton_Click"/>
            <TeachingTip
                x:Name="SetKeyTeachingTip"
                Title="Set New / Update"
                Subtitle="Set new or edit a key value"
                ActionButtonContent="Save"
                ActionButtonCommand="{x:Bind ViewModel.SetKeyConfirmCommand}"
                ActionButtonClick="SetKeyTeachingTip_ActionButtonClick"
                CloseButtonContent="Close"
                IsLightDismissEnabled="False"
                PlacementMargin="20"
                Target="{x:Bind SetKeyButton}">
                <TeachingTip.IconSource>
                    <SymbolIconSource Symbol="Add" />
                </TeachingTip.IconSource>
                <TeachingTip.Content>
                    <StackPanel Spacing="12" Width="400">
                        <TextBlock Text="Key:" />
                        <TextBox x:Name="KeyInput" 
                                 Text="{x:Bind ViewModel.KeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Enter key name" />

                        <TextBlock Text="Value:" Margin="0,12,0,0" />
                        <TextBox x:Name="ValueInput" 
                                 Text="{x:Bind ViewModel.ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Enter value" 
                                 AcceptsReturn="True" 
                                 Height="100" 
                                 TextWrapping="Wrap" />
                    </StackPanel>
                </TeachingTip.Content>
            </TeachingTip>

            <AppBarSeparator />
            <AppBarButton x:Name="ExpireKeyButton" 
                          Icon="Clock" 
                          Label="Set Expiry"
                          Click="ExpireKeyButton_Click"
                          IsEnabled="{x:Bind ViewModel.HasSelectedEntry, Mode=OneWay}"/>

            <TeachingTip 
                 x:Name="ExpireKeyTeachingTip"
                 Title="Set Expiration"
                 Subtitle="Set how many seconds until the key expires"
                 ActionButtonContent="Apply Expire"
                 ActionButtonCommand="{x:Bind ViewModel.ExpireKeyConfirmCommand}"
                 ActionButtonClick="ExpireKeyTeachingTip_ActionButtonClick"
                 CloseButtonContent="Cancel"
                 IsLightDismissEnabled="True"
                 PlacementMargin="20"
                 Target="{x:Bind ExpireKeyButton}"
                 Closed="ExpireKeyTeachingTip_Closed">
                <TeachingTip.IconSource>
                    <SymbolIconSource Symbol="Clock" />
                </TeachingTip.IconSource>
                <TeachingTip.Content>
                    <StackPanel Spacing="12" Width="380">
                        <TextBlock Text="Selected Key:" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Key, Mode=OneWay, FallbackValue='(none)'}" 
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock Text="Expire in (seconds):" Margin="0,12,0,0" />
                        <NumberBox 
                             x:Name="ExpireSecondsInput"
                             Value="{x:Bind ViewModel.ExpireSeconds, Mode=TwoWay}"
                             Minimum="1"
                             Maximum="31536000"     
                             PlaceholderText="e.g. 3600 (1 hour)"
                             SpinButtonPlacementMode="Inline" />

                        <TextBlock Text="Current TTL:" Margin="0,8,0,0"                                      
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <!--Visibility="{x:Bind ViewModel.SelectedEntry.TtlSeconds > 0, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"-->
                        <TextBlock Text="{x:Bind ViewModel.SelectedEntry.TtlSeconds, Mode=OneWay, FallbackValue='No expiration'}"                        
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <!--Visibility="{x:Bind ViewModel.SelectedEntry.TtlSeconds > 0, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"-->
                    </StackPanel>
                </TeachingTip.Content>
            </TeachingTip>
            <AppBarSeparator />
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0" />
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="130"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <controls:DataGrid Grid.Row="1"
                           ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                           SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay, UpdateSourceTrigger=Default}"
                           AutoGenerateColumns="False"
                           IsReadOnly="True">

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Key"     Binding="{Binding Key, Mode=OneWay}"     Width="*" />
                <controls:DataGridTextColumn Header="Type"    Binding="{Binding Type, Mode=OneWay}"    Width="100" />
                <controls:DataGridTextColumn Header="TTL (s)" Binding="{Binding TtlSeconds, Mode=OneWay}" Width="90" />
                <controls:DataGridTextColumn Header="Size (B)" Binding="{Binding SizeBytes, Mode=OneWay}" Width="90" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" Spacing="8" Visibility="{x:Bind ViewModel.HasSelectedEntry, Mode=OneWay}">
            <TextBlock Text="Selected Key:" FontWeight="SemiBold" />
            <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Key, Mode=OneWay}" />
            <TextBlock Text="Value:" FontWeight="SemiBold" Margin="0,8,0,0" />
            <TextBox Text="{x:Bind ViewModel.SelectedEntry.Value, Mode=OneWay}" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     Height="120" />
        </StackPanel>

    </Grid>

</Page>
